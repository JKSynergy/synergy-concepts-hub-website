{
  "name": "sch-website",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./css/tailwind.input.css -o ./css/tailwind.css --minify",
    "build": "npm run build:css",
    "watch:css": "tailwindcss -i ./css/tailwind.input.css -o ./css/tailwind.css --watch",
    "logos": "node scripts/process-client-logos.mjs",
    "prepare:deploy": "node scripts/process-client-logos.mjs && node scripts/prepare-deploy.mjs",
    "deploy": "npm run prepare:deploy && wrangler pages deploy _deploy --project-name=synergywebsite --branch=main --commit-dirty=true"
  },
  "devDependencies": {
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "paystack-sdk": "^3.8.0",
    "tailwind-merge": "^3.6.0"
  }
}
