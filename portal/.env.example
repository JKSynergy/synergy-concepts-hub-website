NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Used for inviting clients. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — email notifications (leave unset to disable on free tier)
RESEND_API_KEY=
EMAIL_FROM=SCH Portal <noreply@synergyconceptshub.com>
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# Optional — staff inbox for new bookings/quote requests
ADMIN_NOTIFY_EMAIL=synergyconceptshub@gmail.com
# Optional — restrict the public /api/quote CORS origin to your marketing site
MARKETING_SITE_ORIGIN=https://synergyconceptshub.com

# Paystack (server-only secret for API calls; public key optional for inline JS)
PAYSTACK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
